# Copy this file to `.env` (same folder) and fill in your Supabase project values.
# Find them in the Supabase dashboard → Project Settings → API.
#
# The anon (public) key is safe to ship in a frontend bundle — Row Level Security
# in the database is what actually protects your data. NEVER put the service_role
# key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
